# ─── Auth ────────────────────────────────────────────────
# API key for all protected endpoints: Authorization: Bearer <API_KEY>
# Public (no key needed): GET /ws, GET /api/market-data/*
# setup.sh generates this automatically — change only if you want to rotate the key.
API_KEY=changeme
# pgp_sym_encrypt key for exchange API credentials (backend-only, never sent to browser)
SERVER_SECRET=changeme

# ─── Postgres ────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
TRADER_POSTGRES_USER=trader
TRADER_POSTGRES_PASSWORD=changeme
TRADER_POSTGRES_DB=trader

# ─── Redis ───────────────────────────────────────────────
REDIS_USERNAME=default
REDIS_PASSWORD=changeme

# ─── RabbitMQ ────────────────────────────────────────────
RABBITMQ_USER=trader
RABBITMQ_PASSWORD=changeme

# ─── ProvenQuant API (optional — for ML signal integration) ──
PROVENQUANT_API_URL=https://www.provenquant.com/api
PROVENQUANT_API_KEY=

# ─── CORS ────────────────────────────────────────────────
# JSON list or comma-separated origins allowed to call the API.
# Dev default ["*"] is fine locally; set your real domain(s) in production:
#   BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]
BACKEND_CORS_ORIGINS=["*"]
